# RV Corp CRM — environment template.
# Copy to `.env.local` and fill in as needed. The demo runs with ZERO of these set
# (in-memory data, deterministic agent, mock auth) — everything below is optional.

# --- Data source ---------------------------------------------------------------
# "local" (default) = in-memory seeded store, no external DB.
# "supabase"        = Prisma/Postgres (requires DATABASE_URL).
DATA_SOURCE_MODE=local
# DATABASE_URL=

# --- Optional LLM enhancement (voice agent v2a) --------------------------------
# Google Gemini (AI Studio free tier). When set, the voice agent adds semantic FAQ
# matching + destination extraction on top of the deterministic core. When ABSENT,
# the agent falls back to the deterministic engine — the demo works either way.
GEMINI_API_KEY=

# Optional lead classifier upgrade (Anthropic). Absent → rule-based classifier.
ANTHROPIC_API_KEY=

# --- Auth / security -----------------------------------------------------------
# HMAC secret for the signed mock session cookie.
DEMO_SESSION_SECRET=
# Shared secrets for the multichannel intake webhook and the follow-up cron.
INTAKE_WEBHOOK_SECRET=
CRON_SECRET=

# --- Notifications (optional; sandbox) -----------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
DEMO_USER_EMAIL=
NEXT_PUBLIC_APP_URL=

# --- Observability -------------------------------------------------------------
# Set to "false" to silence voice-agent telemetry logs.
VOICE_TELEMETRY_ENABLED=
